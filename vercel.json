{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/manifest.webmanifest", "destination": "/public/manifest.webmanifest" },
    { "source": "/sw.js", "destination": "/public/sw.js" },
    { "source": "/icons/:path*", "destination": "/public/icons/:path*" }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "^/(?!api/).*$", "dest": "/index.html" }
  ]
}
